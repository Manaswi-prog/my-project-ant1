{
  "name": "pathwise-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ --ext .js",
    "lint:fix": "eslint src/ tests/ --ext .js --fix",
    "deploy": "npm run build && firebase deploy"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.57.1",
    "jsdom": "^24.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.3",
    "firebase": "^10.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1"
  },
  "vitest": {
    "environment": "jsdom",
    "include": [
      "tests/**/*.test.js"
    ],
    "globals": true
  }
}
