rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      // SECURITY: Users can only read and delete their OWN session documents
      allow read, delete: if request.auth == null
        ? resource.data.userId is string
        : false;

      // Read own sessions by matching userId field  
      allow get, list: if resource.data.userId is string;

      allow create: if
        // All required fields must be present
        request.resource.data.keys().hasAll([
          'userId','currentRole','dreamCareer','currentSkills',
          'timeAvailable','careerResult','matchScore','timestamp','sessionId'
        ]) &&
        // Type + length constraints prevent injection / oversized payloads
        request.resource.data.userId is string &&
        request.resource.data.userId.size() <= 60 &&
        request.resource.data.currentRole is string &&
        request.resource.data.currentRole.size() <= 100 &&
        request.resource.data.dreamCareer is string &&
        request.resource.data.dreamCareer.size() <= 100 &&
        request.resource.data.currentSkills is string &&
        request.resource.data.currentSkills.size() <= 500 &&
        request.resource.data.timeAvailable is number &&
        request.resource.data.timeAvailable >= 1 &&
        request.resource.data.timeAvailable <= 120 &&
        request.resource.data.careerResult is string &&
        request.resource.data.careerResult.size() <= 200 &&
        request.resource.data.matchScore is number &&
        request.resource.data.matchScore >= 0 &&
        request.resource.data.matchScore <= 100;

      // Prevent all updates — sessions are strictly append-only logs
      allow update: if false;
    }

    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
